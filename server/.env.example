# PostgreSQL only (as per project requirement)
DATABASE_URL="postgresql://music_user:music_pass@localhost:5433/music_db?schema=public"

# Production example (replace with your actual DB)
# DATABASE_URL="postgresql://user:pass@your-db-host:5432/music_db?schema=public"

# To run local Postgres easily:
# docker run -d --name music-db -e POSTGRES_USER=music_user -e POSTGRES_PASSWORD=music_pass -e POSTGRES_DB=music_db -p 5433:5432 postgres:15

PORT=3002

# Domain for health checks and CORS
DOMAIN=music.hidar.eu.cc

# CORS origins (comma separated). If not set, defaults will include localhost + DOMAIN
# CORS_ORIGINS=https://music.hidar.eu.cc,https://www.music.hidar.eu.cc

JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Optional
UPLOAD_DIR=public/uploads
